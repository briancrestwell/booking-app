# Production environment template
# Copy to .env.prod and fill in real values — NEVER commit .env.prod to git.

# Docker registry
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/booking-app
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=booking_prod

# PostgreSQL
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=booking_db

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# NestJS
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
CORS_ORIGIN=https://your-domain.com
API_PORT=3001

# Next.js public vars (baked into the JS bundle at build time)
NEXT_PUBLIC_WS_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_DEMO_BRANCH_ID=
NEXT_PUBLIC_MOCK_MODE=false
